# Скопируй в .env и поправь под локальное окружение.
# .env в репозиторий не коммитится.

ENVIRONMENT=development
DEBUG=true

# Используется приложением core, когда оно запускается напрямую (не через docker-compose).
# В docker-compose.dev.yml эти значения переопределяются именами сервисов compose.
DATABASE_URL=postgresql+asyncpg://portal:portal@localhost:5432/portal
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://portal:portal@localhost:5672/

S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=portal
S3_SECRET_KEY=portalpassword
S3_BUCKET=portal

# JWT и cookie auth (см. ADR-0010 backend/docs/adr/0010-...).
# В production обязательно сгенерировать стойкий случайный JWT_SECRET
# (например `openssl rand -hex 32`) и не хранить дефолтный.
JWT_SECRET=dev-only-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# В проде: COOKIE_SECURE=true, COOKIE_SAMESITE=lax (или strict, если
# фронт и бэк на одном домене), COOKIE_DOMAIN=портал.клиент.рф.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
